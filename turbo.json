{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**"
      ],
      "env": [
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_ADMIN_URL",
        "NEXT_PUBLIC_DOCS_URL",
        "NEXT_PUBLIC_AUTH_URL",
        "DATABASE_URL",
        "POSTGRES_URL",
        "PRISMA_DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "NEXT_PUBLIC_BETTER_AUTH_URL"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
