{
  "name": "turborepo-vercel-template",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "rm -rf .turbo && rm -rf apps/**/.turbo apps/**/.next apps/**/dist",
    "db:migrate": "bun run --filter @repo/db migrate:dev",
    "db:migrate:new": "bash packages/db/scripts/migrate-new.sh",
    "db:migrate:deploy": "bun run --filter @repo/db migrate:deploy",
    "db:studio": "bun run --filter @repo/db studio",
    "db:dev": "bun run db:migrate && bun run db:studio"
  },
  "prettier": "@repo/prettier-config",
  "devDependencies": {
    "@repo/prettier-config": "*",
    "effect": "3.21.0",
    "prettier": "^3.7.4",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
