# URL da Vercel onde o app está deployado
NEXT_PUBLIC_APP_URL=https://turborepo-vercel-template-app.vercel.app

# URL da Vercel onde o admin está deployado
NEXT_PUBLIC_ADMIN_URL=https://turborepo-vercel-template-admin.vercel.app

# URL da Vercel onde o docs está deployado
NEXT_PUBLIC_DOCS_URL=https://turborepo-vercel-template-docs.vercel.app

# URL da Vercel onde o auth está deployado (ex: https://meu-auth.vercel.app)
NEXT_PUBLIC_AUTH_URL=https://turborepo-vercel-template-auth.vercel.app

# Banco local (atualizado automaticamente por `bun run db:dev`)
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable&connection_limit=1&connect_timeout=0&max_idle_connection_lifetime=0&pool_timeout=0&socket_timeout=0&pgbouncer=true"

# Better Auth
BETTER_AUTH_SECRET="xxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
